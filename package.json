{
	"name": "laao",
	"version": "0.0.1",
	"description": "Official Block Theme for LAArtsOnline.com",
	"main": "index.js",
	"scripts": {
		"build:blocks": "wp-scripts build --config laao-webpack.config.js --webpack-src-dir=./src/blocks --output-path=./dist/blocks",
		"build:interactivity": "wp-scripts build --webpack-src-dir=./src/blocks-interactivity --output-path=./dist/blocks-interactivity --experimental-modules",
		"build": "pnpm build:blocks & pnpm build:interactivity",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start:blocks": "wp-scripts start --config laao-webpack.config.js --webpack-src-dir=./src/blocks --output-path=./dist/blocks",
		"start:interactivity": "wp-scripts start --webpack-src-dir=./src/blocks-interactivity --output-path=./dist/blocks-interactivity --experimental-modules",
		"start": "concurrently 'pnpm start:interactivity' 'pnpm start:blocks'",
		"start:hot": "wp-scripts start --output-path=./dist --hot",
		"start:copy-php": "wp-scripts start --output-path=./dist --webpack-copy-php",
		"js:watch": "wp-scripts start ./src/scripts/app.js --output-path=dist/scripts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/TheAggressive/LAAO-Theme.git"
	},
	"keywords": [
		"Wordpress",
		"Theme",
		"Blocks",
		"LAArtsOnline.com"
	],
	"author": "The Aggressive, LLC",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/TheAggressive/LAAO-Theme/issues"
	},
	"homepage": "https://github.com/TheAggressive/LAAO-Theme#readme",
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"dependencies": {
		"@wordpress/scripts": "^28.4.0",
		"gsap": "^3.12.5",
		"isomorphic-dompurify": "^2.14.0",
		"lenis": "^1.1.9"
	},
	"devDependencies": {
		"@types/lodash": "^4.17.7",
		"@types/wordpress__block-editor": "^11.5.15",
		"@types/wordpress__block-library": "^2.6.3",
		"@types/wordpress__blocks": "^12.5.14",
		"@types/wordpress__editor": "^13.6.8",
		"@wordpress/a11y": "^4.4.0",
		"@wordpress/api-fetch": "^7.4.0",
		"@wordpress/autop": "^4.4.0",
		"@wordpress/block-editor": "^13.4.0",
		"@wordpress/blocks": "^13.4.0",
		"@wordpress/browserslist-config": "^6.4.0",
		"@wordpress/components": "^28.4.0",
		"@wordpress/core-commands": "^1.4.0",
		"@wordpress/core-data": "^7.4.0",
		"@wordpress/data": "^10.4.0",
		"@wordpress/data-controls": "^4.4.0",
		"@wordpress/dataviews": "^4.0.0",
		"@wordpress/date": "^5.4.0",
		"@wordpress/deprecated": "^4.4.0",
		"@wordpress/dom": "^4.4.0",
		"@wordpress/dom-ready": "^4.4.0",
		"@wordpress/edit-post": "^8.4.0",
		"@wordpress/editor": "^14.4.0",
		"@wordpress/element": "^6.4.0",
		"@wordpress/hooks": "^4.4.0",
		"@wordpress/html-entities": "^4.4.0",
		"@wordpress/i18n": "^5.4.0",
		"@wordpress/icons": "^10.4.0",
		"@wordpress/interactivity": "^6.4.0",
		"@wordpress/patterns": "^2.4.0",
		"@wordpress/plugins": "^7.4.0",
		"@wordpress/preferences": "^4.4.0",
		"@wordpress/prettier-config": "^4.4.0",
		"@wordpress/primitives": "^4.4.0",
		"@wordpress/server-side-render": "^5.4.0",
		"autoprefixer": "^10.4.20",
		"browser-sync-webpack-plugin": "^2.3.0",
		"browserslist": "^4.23.3",
		"concurrently": "^8.2.2",
		"copy-webpack-plugin": "^12.0.2",
		"cssnano": "^7.0.4",
		"lodash": "^4.17.21",
		"postcss": "^8.4.40",
		"postcss-cli": "^11.0.0",
		"postcss-custom-properties": "^13.3.12",
		"postcss-import": "^16.1.0",
		"postcss-mixins": "^10.0.1",
		"postcss-nesting": "^12.1.5",
		"postcss-preset-env": "^9.6.0",
		"postcss-simple-vars": "^7.0.1",
		"prettier": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.5",
		"stylelint": "^16.8.1",
		"stylelint-config-standard": "^36.0.1",
		"stylelint-config-standard-scss": "^13.1.0",
		"tailwindcss": "^3.4.7",
		"webpack-fix-style-only-entries": "^0.6.1",
		"webpack-remove-empty-scripts": "^1.0.4"
	}
}
