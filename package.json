{
	"name": "laao",
	"version": "1.8.1",
	"description": "Official Block Theme for LAArtsOnline.com",
	"author": "The Aggressive, LLC",
	"license": "MIT",
	"main": "index.js",
	"keywords": [
		"Wordpress",
		"Theme",
		"Blocks",
		"LAArtsOnline.com"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/TheAggressive/LAAO-Theme.git"
	},
	"bugs": {
		"url": "https://github.com/TheAggressive/LAAO-Theme/issues"
	},
	"homepage": "https://github.com/TheAggressive/LAAO-Theme#readme",
	"scripts": {
		"prepare": "husky",
		"lint:commit": "commitlint --edit",
		"create-block": "npx @wordpress/create-block@latest --no-plugin --namespace laao",
		"create-block-dynamic": "npx @wordpress/create-block@latest --no-plugin --namespace laao --variant dynamic",
		"create-block-interactive": "npx @wordpress/create-block@latest --no-plugin --namespace laao --template @wordpress/create-block-interactive-template",
		"build:blocks": "wp-scripts build --webpack-src-dir=./src/blocks --output-path=./dist/blocks",
		"build:interactivity": "wp-scripts build --webpack-src-dir=./src/blocks-interactivity --output-path=./dist/blocks-interactivity --experimental-modules",
		"build:assets": "wp-scripts build --config webpack.assets.config.mjs",
		"build": "concurrently 'pnpm build:blocks' 'pnpm build:interactivity' 'pnpm build:assets'",
		"test:js": "wp-scripts test-unit-js",
		"test:js:watch": "wp-scripts test-unit-js --watch",
		"test:php": "vendor/bin/phpunit",
		"test": "concurrently 'pnpm test:php' 'pnpm test:js'",
		"qa": "pnpm lint:js && pnpm lint:css && pnpm test:js && pnpm test:php",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style 'src/**/*.css'",
		"lint:js": "wp-scripts lint-js ./src/**/*.js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start:blocks": "wp-scripts start --webpack-src-dir=./src/blocks --output-path=./dist/blocks",
		"start:interactivity": "wp-scripts start --webpack-src-dir=./src/blocks-interactivity --output-path=./dist/blocks-interactivity --experimental-modules",
		"start:assets": "wp-scripts start --config webpack.assets.config.mjs",
		"start": "concurrently 'pnpm start:blocks' 'pnpm start:interactivity' 'pnpm start:assets'"
	},
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"dependencies": {
		"@wordpress/scripts": "^30.9.0",
		"gsap": "^3.13.0",
		"isomorphic-dompurify": "^2.24.0",
		"lenis": "^1.3.1"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@types/lodash": "^4.17.16",
		"@types/wordpress__block-editor": "^11.5.16",
		"@types/wordpress__block-library": "^2.6.3",
		"@types/wordpress__blocks": "^12.5.17",
		"@wordpress/a11y": "^4.23.0",
		"@wordpress/api-fetch": "^7.23.0",
		"@wordpress/autop": "^4.23.0",
		"@wordpress/block-editor": "^14.18.0",
		"@wordpress/blocks": "^14.12.0",
		"@wordpress/browserslist-config": "^6.23.0",
		"@wordpress/components": "^29.9.0",
		"@wordpress/core-commands": "^1.23.0",
		"@wordpress/core-data": "^7.23.0",
		"@wordpress/data": "^10.23.0",
		"@wordpress/data-controls": "^4.23.0",
		"@wordpress/dataviews": "^4.19.0",
		"@wordpress/date": "^5.23.0",
		"@wordpress/deprecated": "^4.23.0",
		"@wordpress/dom": "^4.23.0",
		"@wordpress/dom-ready": "^4.23.0",
		"@wordpress/edit-post": "^8.23.0",
		"@wordpress/editor": "^14.23.0",
		"@wordpress/element": "^6.23.0",
		"@wordpress/eslint-plugin": "^22.9.0",
		"@wordpress/hooks": "^4.23.0",
		"@wordpress/html-entities": "^4.23.0",
		"@wordpress/i18n": "^5.23.0",
		"@wordpress/icons": "^10.23.0",
		"@wordpress/interactivity": "^6.23.0",
		"@wordpress/patterns": "^2.23.0",
		"@wordpress/plugins": "^7.23.0",
		"@wordpress/preferences": "^4.23.0",
		"@wordpress/prettier-config": "^4.23.0",
		"@wordpress/primitives": "^4.23.0",
		"@wordpress/server-side-render": "^5.23.0",
		"@wordpress/stylelint-config": "^23.15.0",
		"autoprefixer": "^10.4.21",
		"browser-sync-webpack-plugin": "^2.3.0",
		"browserslist": "^4.24.5",
		"concurrently": "^9.1.2",
		"copy-webpack-plugin": "^12.0.2",
		"cssnano": "^7.0.7",
		"fast-glob": "^3.3.3",
		"husky": "^9.1.7",
		"lodash": "^4.17.21",
		"postcss": "^8.5.3",
		"postcss-cli": "^11.0.1",
		"postcss-custom-properties": "^14.0.4",
		"postcss-for": "^2.1.1",
		"postcss-import": "^16.1.0",
		"postcss-mixins": "^11.0.3",
		"postcss-nesting": "^13.0.1",
		"postcss-preset-env": "^10.1.6",
		"postcss-simple-vars": "^7.0.1",
		"prettier": "^3.5.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"semantic-release": "^25.0.3",
		"stylelint": "^16.19.1",
		"stylelint-config-standard": "^38.0.0",
		"stylelint-config-standard-scss": "^14.0.0",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.8.3",
		"webpack-fix-style-only-entries": "^0.6.1",
		"webpack-remove-empty-scripts": "^1.0.4"
	}
}
