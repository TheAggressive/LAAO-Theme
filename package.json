{
	"name": "laao",
	"version": "0.0.1",
	"description": "Official Block Theme for LAArtsOnline.com",
	"main": "index.js",
	"scripts": {
		"build": "wp-scripts build --output-path=./dist",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "wp-scripts start --output-path=./dist",
		"start:hot": "wp-scripts start --output-path=./dist --hot",
		"start:copy-php": "wp-scripts start --output-path=./dist --webpack-copy-php",
		"js:watch": "wp-scripts start ./src/scripts/app.js --output-path=dist/scripts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/TheAggressive/LAAO-Theme.git"
	},
	"keywords": [
		"Wordpress",
		"Theme",
		"Blocks",
		"LAArtsOnline.com"
	],
	"author": "The Aggressive, LLC",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/TheAggressive/LAAO-Theme/issues"
	},
	"homepage": "https://github.com/TheAggressive/LAAO-Theme#readme",
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
