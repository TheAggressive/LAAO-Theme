{
	"name": "laao",
	"version": "0.0.1",
	"description": "Official Block Theme for LAArtsOnline.com",
	"author": "The Aggressive, LLC",
	"license": "MIT",
	"main": "index.js",
	"keywords": [
		"Wordpress",
		"Theme",
		"Blocks",
		"LAArtsOnline.com"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/TheAggressive/LAAO-Theme.git"
	},
	"bugs": {
		"url": "https://github.com/TheAggressive/LAAO-Theme/issues"
	},
	"homepage": "https://github.com/TheAggressive/LAAO-Theme#readme",
	"scripts": {
		"create-block": "npx @wordpress/create-block@latest --no-plugin --namespace laao",
		"create-block-dynamic": "npx @wordpress/create-block@latest --no-plugin --namespace laao --variant dynamic",
		"create-block-interactive": "npx @wordpress/create-block@latest --no-plugin --namespace laao --template @wordpress/create-block-interactive-template",
		"build:blocks": "wp-scripts build --config laao-webpack.config.js --webpack-src-dir=./src/blocks --output-path=./dist/blocks",
		"build:interactivity": "wp-scripts build --webpack-src-dir=./src/blocks-interactivity --output-path=./dist/blocks-interactivity --experimental-modules",
		"build": "pnpm build:blocks & pnpm build:interactivity",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style 'src/**/*.css'",
		"lint:js": "wp-scripts lint-js ./src/**/*.js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start:blocks": "wp-scripts start --config laao-webpack.config.js --webpack-src-dir=./src/blocks --output-path=./dist/blocks",
		"start:interactivity": "wp-scripts start --webpack-src-dir=./src/blocks-interactivity --output-path=./dist/blocks-interactivity --experimental-modules",
		"start": "concurrently 'pnpm start:blocks' 'pnpm start:interactivity'",
		"start:hot": "wp-scripts start --output-path=./dist --hot",
		"start:copy-php": "wp-scripts start --output-path=./dist --webpack-copy-php",
		"js:watch": "wp-scripts start ./src/scripts/app.js --output-path=dist/scripts"
	},
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"dependencies": {
		"@wordpress/scripts": "^30.3.0",
		"gsap": "^3.12.5",
		"isomorphic-dompurify": "^2.16.0",
		"lenis": "^1.1.14"
	},
	"devDependencies": {
		"@types/lodash": "^4.17.13",
		"@types/wordpress__block-editor": "^11.5.15",
		"@types/wordpress__block-library": "^2.6.3",
		"@types/wordpress__blocks": "^12.5.14",
		"@types/wordpress__editor": "^14.3.1",
		"@wordpress/a11y": "^4.11.0",
		"@wordpress/api-fetch": "^7.11.0",
		"@wordpress/autop": "^4.11.0",
		"@wordpress/block-editor": "^14.6.0",
		"@wordpress/blocks": "^14.0.0",
		"@wordpress/browserslist-config": "^6.11.0",
		"@wordpress/components": "^28.11.0",
		"@wordpress/core-commands": "^1.11.0",
		"@wordpress/core-data": "^7.11.0",
		"@wordpress/data": "^10.11.0",
		"@wordpress/data-controls": "^4.11.0",
		"@wordpress/dataviews": "^4.7.0",
		"@wordpress/date": "^5.11.0",
		"@wordpress/deprecated": "^4.11.0",
		"@wordpress/dom": "^4.11.0",
		"@wordpress/dom-ready": "^4.11.0",
		"@wordpress/edit-post": "^8.11.0",
		"@wordpress/editor": "^14.11.0",
		"@wordpress/element": "^6.11.0",
		"@wordpress/eslint-plugin": "^21.4.0",
		"@wordpress/hooks": "^4.11.0",
		"@wordpress/html-entities": "^4.11.0",
		"@wordpress/i18n": "^5.11.0",
		"@wordpress/icons": "^10.11.0",
		"@wordpress/interactivity": "^6.11.0",
		"@wordpress/patterns": "^2.11.0",
		"@wordpress/plugins": "^7.11.0",
		"@wordpress/preferences": "^4.11.0",
		"@wordpress/prettier-config": "^4.11.0",
		"@wordpress/primitives": "^4.11.0",
		"@wordpress/server-side-render": "^5.11.0",
		"@wordpress/stylelint-config": "^23.3.0",
		"autoprefixer": "^10.4.20",
		"browser-sync-webpack-plugin": "^2.3.0",
		"browserslist": "^4.24.2",
		"concurrently": "^9.1.0",
		"copy-webpack-plugin": "^12.0.2",
		"cssnano": "^7.0.5",
		"lodash": "^4.17.21",
		"postcss": "^8.4.41",
		"postcss-cli": "^11.0.0",
		"postcss-custom-properties": "^14.0.4",
		"postcss-import": "^16.1.0",
		"postcss-mixins": "^11.0.3",
		"postcss-nesting": "^13.0.1",
		"postcss-preset-env": "^10.0.9",
		"postcss-simple-vars": "^7.0.1",
		"prettier": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.8",
		"stylelint": "^16.10.0",
		"stylelint-config-standard": "^36.0.1",
		"stylelint-config-standard-scss": "^13.1.0",
		"tailwindcss": "^3.4.14",
		"typescript": "^5.6.3",
		"webpack-fix-style-only-entries": "^0.6.1",
		"webpack-remove-empty-scripts": "^1.0.4"
	}
}
