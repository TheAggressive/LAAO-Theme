{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "laao/query-loop-ad-inserter",
	"version": "1.0.0",
	"title": "Query Loop Ad Inserter",
	"category": "widgets",
	"description": "Insert Ads in the query loop.",
	"example": {},
