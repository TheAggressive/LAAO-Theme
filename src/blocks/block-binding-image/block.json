{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "laao/block-binding-image",
	"version": "0.1.0",
	"title": "Block Binding Image",
	"category": "widgets",
	"icon": "smiley",
	"description": "Example block scaffolded with Create Block tool.",
	"example": {},
	"supports": {
		"html": false
	},
	"attributes": {
		"metaKey": {
			"type": "string",
			"default": "photo_2"
		},
		"sizeSlug": {
			"type": "string",
			"default": "medium"
		}
	},
	"textdomain": "block-binding-image",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"usesContext": ["postId", "postType"]
}
