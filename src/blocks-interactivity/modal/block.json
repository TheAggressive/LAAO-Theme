{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "laao/modal",
	"version": "1.0.0",
	"title": "Modal",
	"category": "widgets",
	"icon": "media-interactive",
	"description": "An interactive modal block that can be positioned and triggered by other elements.",
	"example": {},
	"supports": {
		"interactivity": true,
		"html": false,
		"align": true,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"__experimentalBorder": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true,
			"__experimentalDefaultControls": {
				"color": true,
				"radius": true,
				"style": true,
				"width": true
			}
		},
		"shadow": true,
		"color": {
			"background": true,
			"text": false
		}
	},
	"textdomain": "modal",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js",
	"attributes": {
		"position": {
			"type": "string",
			"default": "center"
		},
		"openOnLoad": {
			"type": "boolean",
			"default": false
		},
		"disableOverlay": {
			"type": "boolean",
			"default": false
		},
		"enterAnimation": {
			"type": "string",
			"default": "fade"
		},
		"exitAnimation": {
			"type": "string",
			"default": "fade"
		},
		"animationDuration": {
			"type": "number",
			"default": 300
		},
		"modalId": {
			"type": "string",
			"default": ""
		},
		"triggerBlockId": {
			"type": "string",
			"default": ""
		},
		"triggerBlockAnchor": {
			"type": "string",
			"default": ""
		},
		"triggerLabel": {
			"type": "string",
			"default": "Open Modal"
		},
		"style": {
			"type": "object",
			"default": {
				"border": {
					"radius": "0px",
					"width": "1.5rem",
					"style": "solid",
					"color": "var(--wp--preset--color--laao-white)"
				},
				"color": {
					"background": "var(--wp--preset--color--laao-light-gray)"
				}
			}
		}
	}
}
