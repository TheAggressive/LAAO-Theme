{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "laao/modal",
	"version": "0.1.0",
	"title": "Modal",
	"category": "widgets",
	"icon": "media-interactive",
	"description": "An interactive modal block that can be positioned and triggered by other elements.",
	"example": {},
	"supports": {
		"interactivity": true,
		"html": false,
		"align": true
	},
	"textdomain": "modal",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js",
	"attributes": {
		"position": {
			"type": "string",
			"default": "center"
		},
		"openOnLoad": {
			"type": "boolean",
			"default": false
		},
		"modalId": {
			"type": "string",
			"default": ""
		},
		"triggerBlockId": {
			"type": "string",
			"default": ""
		},
		"triggerBlockAnchor": {
			"type": "string",
			"default": ""
		},

		"triggerLabel": {
			"type": "string",
			"default": "Open Modal"
		}
	}
}
