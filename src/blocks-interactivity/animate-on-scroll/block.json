{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "laao/animate-on-scroll",
	"version": "0.1.0",
	"title": "Animate On Scroll",
	"category": "widgets",
	"icon": "media-interactive",
	"description": "Animate elements on scroll.",
	"example": {},
	"supports": {
		"html": false,
		"interactivity": true
	},
	"attributes": {
		"animation": {
			"type": "string",
			"default": "fade"
		},
		"direction": {
			"type": "string",
			"default": "up"
		},
		"staggerChildren": {
			"type": "boolean",
			"default": false
		},
		"staggerDelay": {
			"type": "number",
			"default": 0.2
		},
		"duration": {
			"type": "number",
			"default": 0.5
		},
		"rootMargin": {
			"type": "string",
			"default": "-30%"
		}
	},
	"textdomain": "laao",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js"
}
